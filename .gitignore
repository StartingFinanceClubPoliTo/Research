# =============================================================================
# .gitignore for Starting Finance Club PoliTo - Research repository
# Covers: Python, R, Jupyter notebooks, LaTeX, common OS/IDE files
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
develop-eggs/
sdist/
wheels/
share/python-wheels/
MANIFEST

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Type checkers / linters caches
.mypy_cache/
.ruff_cache/
.pyre/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*-checkpoint.ipynb
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# R
# -----------------------------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
*.Rproj
.Renviron

# RStudio
.Rcheck/
*_cache/
/cache/

# knitr / R Markdown
*.utf8.md
*.knit.md

# -----------------------------------------------------------------------------
# LaTeX (in case article .tex sources are committed in the future)
# -----------------------------------------------------------------------------
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.nav
*.snm
*.vrb
*.dvi
*.run.xml

# Final article PDFs are kept in the repository — do NOT ignore *.pdf globally.
# If you want to ignore intermediate PDFs, do so on a per-folder basis.

# -----------------------------------------------------------------------------
# Raw data and large files
# -----------------------------------------------------------------------------
# Excel source files contain private working notes and are excluded from the
# repository. See each article's README for instructions on how to obtain
# the underlying data from public sources.
*.xlsx
*.xls

# Other heavy data formats — uncomment if needed:
# *.csv
# *.parquet
# *.pkl
# *.h5
# *.feather

# Typical intermediate data cache folders
**/Data/cache/
**/data/cache/
**/__cache__/

# Very heavy simulation outputs (>50 MB) — keep them local
*.npz
*_simulation_output.*
*_montecarlo_paths.*

# -----------------------------------------------------------------------------
# Credentials, secrets, private configuration
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.pfx
secrets.json
credentials.json
config.local.*

# Interactive Brokers / Trading API
ib_credentials.*
*.ibcfg

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject
.history/

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Large archives that should NOT end up on GitHub
# (GitHub blocks files > 100 MB; warns above 50 MB)
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.7z
*.rar
*.iso
